datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String   // Armazena o 'username' enviado pelo front-end
  email     String   @unique
  password  String
  role      String   @default("membro") // Controla o nível de acesso: "gerente" ou "membro"
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  // Relacionamentos
  ownedProjects Project[]       @relation("ProjectOwner")
  tasks         Task[]
  sprints       Sprint[]
  memberships   ProjectMember[] // Projetos nos quais este usuário foi adicionado como membro
  comments      Comment[]       // Comentários criados por este usuário

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relacionamento com o Gerente (Dono do Projeto)
  ownerId     String   @map("owner_id")
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Relacionamentos Inversos
  tasks       Task[]
  members     ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userEmail String   @map("user_email")
  user      User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)

  @@map("project_members")
}

model Task {
  id                String    @id @default(uuid())
  title             String
  desc              String?   // Nome exato mapeado pelo seu storage.js do front-end
  status            String    @default("backlog") // Alinhado com TASK_STATUS: backlog, todo, doing, done
  column            String    @default("backlog") // Coluna visual do SortableJS/Kanban
  priority          String    @default("medium")  // Alinhado com TASK_PRIORITY: low, medium, high
  responsible       String    @default("Não atribuído") // Vinculado à busca por membros do Dashboard
  progress          Int       @default(0)         // Percentual de conclusão da tarefa (0 a 100)
  dueDate           String?   @map("due_date")    // Armazena o prazo vindo da interface
  inSprint          Boolean   @default(false)     @map("in_sprint")
  completedInSprint Boolean   @default(false)     @map("completed_in_sprint")
  createdAt         DateTime  @default(now())     @map("created_at")
  updatedAt         DateTime  @updatedAt          @map("updated_at")

  // Relacionamento com o Projeto
  projectId         String    @map("project_id")
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Relacionamento opcional com Sprints
  sprintId          String?   @map("sprint_id")
  sprint            Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  // Relacionamento com o Usuário que registou/criou a tarefa
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relacionamento com Comentários
  comments          Comment[]

  @@map("tasks")
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relacionamento com a Tarefa
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Relacionamento com o Autor do comentário
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Sprint {
  id        String    @id @default(uuid())
  name      String
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  status    String    @default("active") // Alinhado com SPRINT_STATUS: planned, active, closed
  createdAt DateTime  @default(now()) @map("created_at")

  // Relacionamento com o Criador da Sprint
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@map("sprints")
}